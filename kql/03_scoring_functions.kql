// ---------------------------------------------------------------------------
// build_multivariate_windows_batch
//
// Update-policy variant for multi-sensor windows on one machine. Strategy
// mirrors build_univariate_windows_batch:
//   - direct raw_telemetry ref to get extent-filtered new data,
//   - bin by `bin`, fan in sensors per bin,
//   - pull (window_size - 1) preceding bins as context,
//   - keep only windows whose window_end falls in the new batch.
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Build aligned multi-sensor windows from the new extent + minimal context. For update-policy use.')
    build_multivariate_windows_batch(
        machine:string, sensors:dynamic,
        window_size:int, bin:timespan
    ) {
    let new_bins = raw_telemetry  // extent-filtered when called from update policy
        | where machine_id == machine and sensor_id in (sensors)
        | summarize avg_value = avg(value)
            by bin = bin(ts, bin), machine_id, sensor_id
        | summarize sensor_values = make_bag(pack(sensor_id, avg_value))
            by bin, machine_id;
    let new_bin_min = toscalar(new_bins | summarize min(bin));
    let context = database(current_database()).raw_telemetry
        | where machine_id == machine and sensor_id in (sensors) and ts < new_bin_min
        | summarize avg_value = avg(value)
            by bin = bin(ts, bin), machine_id, sensor_id
        | summarize sensor_values = make_bag(pack(sensor_id, avg_value))
            by bin, machine_id
        | top (window_size - 1) by bin desc;
    union context, new_bins
    | order by bin asc
    | extend rn = row_number() - 1
    | extend win_id = rn / window_size
    | summarize
        window_start = min(bin),
        window_end   = max(bin),
        values       = make_list(sensor_values)
        by machine_id, win_id
    | where array_length(values) == window_size
    | where window_end >= new_bin_min
    | project-away win_id
}

// ---------------------------------------------------------------------------
// build_multivariate_windows_lookback
//
// Ad-hoc / backfill variant.
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Build aligned multi-sensor windows over a fixed lookback. For ad-hoc use.')
    build_multivariate_windows_lookback(
        machine:string, sensors:dynamic,
        window_size:int, bin:timespan, lookback:timespan
    ) {
    database(current_database()).raw_telemetry
    | where machine_id == machine and sensor_id in (sensors)
    | where ts > now() - lookback
    | summarize avg_value = avg(value)
        by bin = bin(ts, bin), machine_id, sensor_id
    | summarize sensor_values = make_bag(pack(sensor_id, avg_value))
        by bin, machine_id
    | order by bin asc
    | extend rn = row_number() - 1
    | extend win_id = rn / window_size
    | summarize
        window_start = min(bin),
        window_end   = max(bin),
        values       = make_list(sensor_values)
        by machine_id, win_id
    | where array_length(values) == window_size
    | project-away win_id
}

// ---------------------------------------------------------------------------
// score_multivariate_onnx_batch
//
// For update-policy use.
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Score the new-batch multivariate windows of one machine with an ONNX model')
    score_multivariate_onnx_batch(
        model_name:string, machine:string,
        bin:timespan, threshold:real
    ) {
    let m         = latest_model(model_name);
    let model_b64 = toscalar(m | project payload);
    let model_ver = toscalar(m | project version);
    let win_size  = toint(toscalar(m | project window_size));
    let sensors   = toscalar(m | project sensors);
    build_multivariate_windows_batch(machine, sensors, win_size, bin)
    | extend model_b64 = model_b64, sensors = sensors
    | evaluate python(
        typeof(*, score:real),
```
import base64, numpy as np, onnxruntime as ort
if len(df) == 0:
    result = df.copy()
    result['score'] = np.array([], dtype=float)
else:
    b64 = df['model_b64'].iloc[0]
    sensors = list(df['sensors'].iloc[0])
    sess = ort.InferenceSession(base64.b64decode(b64))
    input_name = sess.get_inputs()[0].name
    batch = []
    for row in df['values']:
        mat = np.array([[step.get(s, 0.0) for s in sensors] for step in row], dtype=np.float32)
        batch.append(mat)
    X = np.stack(batch)
    out = sess.run(None, {input_name: X})[0].reshape(-1)
    result = df.copy()
    result['score'] = out
```
    )
    | project-away model_b64, sensors
    | extend
        model_name    = model_name,
        model_version = model_ver,
        is_anomaly    = score > threshold,
        detected_at   = now()
}

