// 03_scoring_functions.kql
// Stored functions that build sliding windows and call the ONNX model
// in-process via the python() plugin.
//
// Two variants per family:
//
//   *_batch     → designed to be called from an UPDATE POLICY. Reads only
//                 the new extent + a tiny (window_size - 1) prefix from
//                 history. Cost is proportional to the new data; each
//                 window is scored exactly once across the lifetime of
//                 the pipeline. THIS is the one used in production.
//
//   *_lookback  → designed for AD-HOC use (notebooks, manual queries,
//                 backfill). Reads a fixed lookback window from the full
//                 table and re-emits the same windows on every call →
//                 not idempotent, do NOT plug directly into an update
//                 policy.
//
// Prerequisites
// -------------
// * The python() language plugin must be enabled on the Eventhouse AND on
//   every KQL Database that uses it (see anomaly_detection_fabric_kql.md
//   §2.1 — the Eventhouse-level toggle does not cascade).
// * Models must already exist in the `models` table (uploaded by the
//   training notebook) with name = model_name and a valid base64 ONNX
//   payload.

// ---------------------------------------------------------------------------
// build_univariate_windows_batch
//
// Call ONLY from an update policy. The direct `raw_telemetry` reference
// gets extent-filtered by the engine, so it returns just the rows of the
// new batch. We pull the (window_size - 1) preceding samples for the same
// (machine, sensor) so that windows straddling the batch boundary are
// emitted exactly once — by the batch that contains their last sample.
//
// Output: one row per complete window whose `window_end` falls in the new
// batch's timestamp range. No duplicates across batches, no data loss
// between batches.
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Build windows for one (machine, sensor) from the new extent + minimal context. For update-policy use.')
    build_univariate_windows_batch(
        machine:string, sensor:string,
        window_size:int
    ) {
    let new_data = raw_telemetry  // extent-filtered when called from update policy
        | where machine_id == machine and sensor_id == sensor
        | project ts, value;
    let new_ts_min = toscalar(new_data | summarize min(ts));
    // (window_size - 1) preceding samples = enough to complete any window
    // that straddles the boundary between this batch and the previous data.
    let context = database(current_database()).raw_telemetry
        | where machine_id == machine and sensor_id == sensor and ts < new_ts_min
        | top (window_size - 1) by ts desc
        | project ts, value;
    union context, new_data
    | order by ts asc
    | extend rn = row_number() - 1
    | extend win_id = rn / window_size
    | summarize
        window_start = min(ts),
        window_end   = max(ts),
        values       = make_list(value)
        by win_id
    | where array_length(values) == window_size
    | where window_end >= new_ts_min  // skip windows entirely in the past
    | extend machine_id = machine, sensor_id = sensor
    | project-away win_id
}

// ---------------------------------------------------------------------------
// build_univariate_windows_lookback
//
// Ad-hoc / backfill variant. Reads `lookback` worth of history from the
// full table and chops it into non-overlapping fixed-size windows. Same
// window every call → DO NOT use in an update policy (would create
// duplicates).
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Build windows for one (machine, sensor) over a fixed lookback. For ad-hoc use.')
    build_univariate_windows_lookback(
        machine:string, sensor:string,
        window_size:int, lookback:timespan
    ) {
    database(current_database()).raw_telemetry
    | where machine_id == machine and sensor_id == sensor
    | where ts > now() - lookback
    | order by ts asc
    | extend rn = row_number() - 1
    | extend win_id = rn / window_size
    | summarize
        window_start = min(ts),
        window_end   = max(ts),
        values       = make_list(value)
        by machine_id, sensor_id, win_id
    | where array_length(values) == window_size
    | project-away win_id
}

// ---------------------------------------------------------------------------
// score_univariate_onnx_batch
//
// For update-policy use. Scores only windows that complete in the new batch.
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Score the new-batch windows of one (machine, sensor) with an ONNX model')
    score_univariate_onnx_batch(
        model_name:string, machine:string, sensor:string,
        window_size:int, threshold:real
    ) {
    let model_row = toscalar(latest_model(model_name) | project payload);
    let model_ver = toscalar(latest_model(model_name) | project version);
    build_univariate_windows_batch(machine, sensor, window_size)
    | extend model_b64 = model_row
    | evaluate python(
        typeof(*, score:real),
```
import base64, numpy as np, onnxruntime as ort
if len(df) == 0:
    result = df.copy()
    result['score'] = np.array([], dtype=float)
else:
    b64 = df['model_b64'].iloc[0]
    sess = ort.InferenceSession(base64.b64decode(b64))
    input_name = sess.get_inputs()[0].name
    X = np.stack(df['values'].values).astype(np.float32)
    X = X.reshape(X.shape[0], X.shape[1], 1)
    out = sess.run(None, {input_name: X})[0].reshape(-1)
    result = df.copy()
    result['score'] = out
```
    )
    | project-away model_b64
    | extend
        model_name    = model_name,
        model_version = model_ver,
        is_anomaly    = score > threshold,
        detected_at   = now()
}

// ---------------------------------------------------------------------------
