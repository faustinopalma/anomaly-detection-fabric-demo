// 03_scoring_functions.kql
// Stored functions that build sliding windows and call the ONNX model
// in-process via the python() plugin.
//
// Prerequisites
// -------------
// * The python() language plugin must be enabled on the Eventhouse.
//   Ask a workspace/cluster admin if it is not.
// * Models must already exist in the `models` table (uploaded by the
//   training notebook) with name = model_name and a valid base64 ONNX
//   payload.

// ---------------------------------------------------------------------------
// build_univariate_windows
//   For one sensor of one machine, produce non-overlapping fixed-size
//   windows of length `window_size` ending at or before `until`.
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Build fixed-length windows for a single (machine, sensor)')
    build_univariate_windows(
        machine:string, sensor:string,
        window_size:int, lookback:timespan
    ) {
    // We use `database(current_database()).raw_telemetry` (instead of plain
    // `raw_telemetry`) so that when this function is invoked from an update
    // policy, the engine does NOT rewrite the source to be filtered by the
    // single new extent. We need the FULL recent history to be able to build
    // 64-sample windows; otherwise each per-extent invocation only sees a
    // tiny slice and `array_length(values) == window_size` is never true.
    // See: https://learn.microsoft.com/kusto/management/update-policy
    database(current_database()).raw_telemetry
    | where machine_id == machine and sensor_id == sensor
    | where ts > now() - lookback
    | order by ts asc
    | extend rn = row_number() - 1
    | extend win_id = rn / window_size
    | summarize
        window_start = min(ts),
        window_end   = max(ts),
        values       = make_list(value)
        by machine_id, sensor_id, win_id
    | where array_length(values) == window_size
    | project-away win_id
}

// ---------------------------------------------------------------------------
// score_univariate_onnx
//   Pass each window through the latest ONNX model named `model_name`.
//   The model must accept input shape [batch, window_size, 1] (float32)
//   and return a 1-D anomaly score per row.
// ---------------------------------------------------------------------------
.create-or-alter function with (folder='scoring',
        docstring='Score univariate windows with an ONNX model')
    score_univariate_onnx(
        model_name:string, machine:string, sensor:string,
        window_size:int, lookback:timespan, threshold:real
    ) {
    let model_row = toscalar(latest_model(model_name) | project payload);
    let model_ver = toscalar(latest_model(model_name) | project version);
    build_univariate_windows(machine, sensor, window_size, lookback)
    | extend model_b64 = model_row
    | evaluate python(
        typeof(*, score:real),
```
import base64, io, numpy as np, onnxruntime as ort
if len(df) == 0:
    result = df.copy()
    result['score'] = np.array([], dtype=float)
else:
    b64 = df['model_b64'].iloc[0]
    sess = ort.InferenceSession(base64.b64decode(b64))
    input_name = sess.get_inputs()[0].name
    X = np.stack(df['values'].values).astype(np.float32)
    X = X.reshape(X.shape[0], X.shape[1], 1)
    out = sess.run(None, {input_name: X})[0].reshape(-1)
    result = df.copy()
    result['score'] = out
