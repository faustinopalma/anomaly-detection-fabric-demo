# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Entra tenant that owns the Fabric capacity
FABRIC_TENANT_ID=00000000-0000-0000-0000-000000000000

# Existing Fabric capacity name (must already exist and be active)
FABRIC_CAPACITY_NAME=MyFabricCapacity

# Workspace to create / update
FABRIC_WORKSPACE_NAME=anomaly-detection-dev

# --- Item names (all created blank; notebooks are imported from items/) ---
FABRIC_EVENTSTREAM_NAME=es-machines
FABRIC_EVENTHOUSE_NAME=eh-telemetry
FABRIC_KQLDB_NAME=kql-telemetry
FABRIC_LAKEHOUSE_NAME=lh-telemetry
FABRIC_ENVIRONMENT_NAME=env-anomaly
FABRIC_NOTEBOOK_FEATURES_NAME=nb-prepare-features
FABRIC_NOTEBOOK_TRAIN_NAME=nb-train-export-onnx
FABRIC_NOTEBOOK_REGISTER_NAME=nb-register-kql-scorer
FABRIC_PIPELINE_NAME=pl-retrain
FABRIC_ACTIVATOR_NAME=act-anomaly-alerts
FABRIC_SEMANTIC_MODEL_NAME=sm-anomaly
FABRIC_REPORT_NAME=rpt-anomaly
