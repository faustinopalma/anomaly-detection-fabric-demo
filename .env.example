# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Entra tenant that owns the Fabric capacity
FABRIC_TENANT_ID=00000000-0000-0000-0000-000000000000

# Existing Fabric capacity name (must already exist and be active)
FABRIC_CAPACITY_NAME=MyFabricCapacity

# Workspace to create / update
FABRIC_WORKSPACE_NAME=anomaly-detection-dev

# Item names (all created blank)
FABRIC_LAKEHOUSE_NAME=lakehouse1
FABRIC_NOTEBOOK_NAME=notebook1
FABRIC_PIPELINE_NAME=pipeline1
FABRIC_EVENTHOUSE_NAME=eventhouse1
FABRIC_KQLDB_NAME=kqldb1
