# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Entra tenant that owns the Fabric capacity
FABRIC_TENANT_ID=00000000-0000-0000-0000-000000000000

# Existing Fabric capacity name (must already exist and be active).
# To create one, use: pwsh ./scripts/create-capacity.ps1 (see below).
FABRIC_CAPACITY_NAME=MyFabricCapacity

# --- Used only by scripts/create-capacity.ps1 ---------------------------
# Azure subscription that will host the Fabric capacity (optional - if
# omitted, the current `az account show` context is used).
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
# Resource group to create / use for the capacity.
AZURE_RESOURCE_GROUP=rg-fabric-demo
# Azure region for the capacity (default: italynorth).
AZURE_LOCATION=italynorth
# Fabric SKU (default: F4). Allowed: F2, F4, F8, F16, F32, F64, F128, F256, F512, F1024, F2048.
FABRIC_CAPACITY_SKU=F4
# Comma-separated UPNs (or object ids) of capacity admins. Defaults to the
# signed-in user when omitted.
FABRIC_CAPACITY_ADMINS=user1@contoso.com

# Workspace to create / update
FABRIC_WORKSPACE_NAME=anomaly-detection-dev

# --- Item names (all created blank; notebooks are imported from items/) ---
# Note: some Fabric item types (Eventstream, Reflex, ...) reject hyphens, so
# names use underscores throughout for consistency.
FABRIC_EVENTSTREAM_NAME=es_machines
FABRIC_EVENTHOUSE_NAME=eh_telemetry
FABRIC_KQLDB_NAME=kql_telemetry
FABRIC_LAKEHOUSE_NAME=lh_telemetry
FABRIC_ENVIRONMENT_NAME=env_anomaly
FABRIC_NOTEBOOK_REGISTER_NAME=nb_register_kql_scorer
FABRIC_PIPELINE_NAME=pl_retrain
FABRIC_ACTIVATOR_NAME=act_anomaly_alerts
FABRIC_SEMANTIC_MODEL_NAME=sm_anomaly
FABRIC_REPORT_NAME=rpt_anomaly

# --- Eventstream Custom Endpoint (Event Hubs compatible) ----------------
# After deploy.ps1 runs, open the Eventstream `es_machines` in the Fabric
# portal, add a source of type "Custom App" / "Custom Endpoint", then on the
# source's Details pane > Event Hub > SAS Key Authentication copy the value
# of "Connection string-primary key" here. Format:
#   Endpoint=sb://eventstream-xxxx.servicebus.windows.net/;SharedAccessKeyName=key_xxx;SharedAccessKey=xxxx;EntityPath=es_xxxx
EVENTSTREAM_CONNECTION_STRING=
